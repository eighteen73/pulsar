{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"border": {
			"color": true,
			"radius": true,
			"style": false,
			"width": false,
			"radiusSizes": [
				{
					"name": "xs",
					"slug": "xs",
					"size": "4px"
				},
				{
					"name": "sm",
					"slug": "sm",
					"size": "8px"
				},
				{
					"name": "md",
					"slug": "md",
					"size": "clamp(10px, 1.5vw, 16px)"
				},
				{
					"name": "lg",
					"slug": "lg",
					"size": "clamp(16px, 2.5vw, 24px)"
				},
				{
					"name": "xl",
					"slug": "xl",
					"size": "clamp(24px, 3.5vw, 48px)"
				},
				{
					"name": "2-xl",
					"slug": "2-xl",
					"size": "clamp(48px, 4.5vw, 96px)"
				},
				{
					"name": "full",
					"slug": "full",
					"size": "100%"
				}
			]
		}
	}
}
