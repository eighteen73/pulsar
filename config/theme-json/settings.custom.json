{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"custom": {
			"color": {
				"primitive": {
					"neutral": {
            "0": "#FFFFFF",
						"50": "#F8FAFC",
            "100": "#F1F5F9",
            "200": "#E2E8F0",
            "300": "#CBD5E1",
            "400": "#94A3B8",
            "500": "#64748B",
            "600": "#475569",
            "700": "#334155",
            "800": "#1E293B",
            "900": "#0F172A",
            "950": "#020617",
            "1000": "#000000"
					},
					"primary": {
						"50": "#F8FAFF",
            "100": "#EDF2FF",
            "200": "#D1DBF0",
            "300": "#A3B6D9",
            "400": "#6F89BC",
            "500": "#4D669C",
            "600": "#3B4E7A",
            "700": "#2F3E61",
            "800": "#25314D",
            "900": "#1C253B",
            "950": "#111724"
					},
					"secondary": {
						"50": "#FFF9F2",
            "100": "#FEEED9",
            "200": "#FBD8B1",
            "300": "#F7BD81",
            "400": "#F29D4F",
            "500": "#D97706",
            "600": "#B45309",
            "700": "#92400E",
            "800": "#78350F",
            "900": "#5F2A0C",
            "950": "#3D1A07"
					},
					"error": {
						"100": "#FEE2E2",
						"500": "#F44336",
						"900": "#7F1D1D"
					},
					"warning": {
						"100": "#FEF3C7",
						"500": "#F59E0B",
						"900": "#C75F18"
					},
					"success": {
						"100": "#DCFCE7",
						"500": "#67C23A",
						"900": "#14532D"
					}
				},
				"link": "var:custom|color|primitive|primary|600",
				"focus": "#fd0",
				"focus-accent": "var:custom|color|primitive|neutral|800",
				"error": "var:custom|color|primitive|error|900",
				"error-accent": "var:custom|color|primitive|error|100",
				"warning": "var:custom|color|primitive|warning|500",
				"warning-accent": "var:custom|color|primitive|warning|100",
				"success": "var:custom|color|primitive|success|900",
				"success-accent": "var:custom|color|primitive|success|100",
				"shadow": "var:custom|color|primitive|neutral|900",
				"border": "var:custom|color|primitive|neutral|200",
				"border-invert": "var:custom|color|primitive|neutral|800",
				"border-input": "var:custom|color|primitive|neutral|400",
				"border-input-invert": "var:custom|color|primitive|neutral|200"
			},
			"global": {
				"is-rounded": 0
			},
			"layout": {
				"content": "768px",
				"wide": "1280px"
			},
			"spacing": {
				"blockGap": "var:preset|spacing|xl",
				"blockGapSmall": "var:preset|spacing|md",
				"groupGap": "var:preset|spacing|5-xl",
				"rowGap": "clamp(var(--wp--preset--spacing--2-xl), 5.3333px + 5.8333vw, var(--wp--preset--spacing--4-xl))",
				"columnGap": "var:preset|spacing|3-xl",
				"edge": "clamp(var(--wp--preset--spacing--2-xl), 5.3333px + 5.8333vw, var(--wp--preset--spacing--6-xl))"
			},
			"border": {
				"radius": {
					"xs": "4px",
					"sm": "8px",
					"md": "clamp(10px, 1.5vw, 16px)",
					"lg": "clamp(16px, 2.5vw, 24px)",
					"xl": "clamp(24px, 3.5vw, 48px)",
					"2-xl": "clamp(48px, 4.5vw, 96px)",
					"full": "100%"
				}
			},
			"typography": {
				"fontWeight": {
					"body": 400,
					"heading": 700
				},
				"lineHeight": {
					"none": "1",
					"tight": "1.1",
					"snug": "1.375",
					"normal": "1.5",
					"relaxed": "1.6",
					"loose": "2"
				},
				"letterSpacing": {
					"tighter": "-0.05em",
					"tight": "-0.025em",
					"normal": "0em",
					"wide": "0.025em",
					"wider": "0.05em"
				}
			},
			"transition": {
				"duration": {
					"quick": "150ms",
					"normal": "300ms",
					"slow": "600ms"
				},
				"timing": {
					"ease-in": "ease-in",
					"ease-out": "ease-out"
				}
			}
		}
	}
}
